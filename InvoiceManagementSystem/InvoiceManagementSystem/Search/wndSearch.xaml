<Window x:Class="InvoiceManagementSystem.Search.wndSearch"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Search Invoices" Height="450" Width="800">

    <Grid Margin="10">
        <StackPanel>

            <Label Content="Filter by Invoice Number"/>
            <ComboBox Name="cboInvoiceNum" Width="200" Margin="0,0,0,10"/>

            <Label Content="Filter by Date"/>
            <ComboBox Name="cboDate" Width="200" Margin="0,0,0,10"/>

            <Label Content="Filter by Total Cost"/>
            <ComboBox Name="cboTotalCost" Width="200" Margin="0,0,0,10"/>

            <DataGrid Name="dgInvoices" Height="200" Margin="0,10,0,10"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Name="btnSelect" Content="Select" Width="100" Margin="5" Click="btnSelect_Click"/>
                <Button Name="btnCancel" Content="Cancel" Width="100" Margin="5" Click="btnCancel_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>
